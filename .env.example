# Kiosko Azul - Variables de Entorno
# Copia este archivo como .env y ajusta los valores

# ⚠️ IMPORTANTE: Genera una clave segura para producción
# Puedes usar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=kioskoazul-secret-2025-xK9mPqR

# Tiempo de expiración del token JWT en horas
TOKEN_HOURS=24

# Dominios permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000

# URL base del sitio (para SEO y sitemap)
BASE_URL=https://kioskoazul.com

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=tu-bot-token-aqui
TELEGRAM_CHAT_ID=tu-chat-id-aqui

# SMTP para recuperación de contraseñas (opcional)
SMTP_EMAIL=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password